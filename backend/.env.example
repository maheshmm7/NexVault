# NEXVAULT API Environment Configuration Template
# Duplicate this file as '.env' inside the backend folder and fill in the parameters.

PROJECT_NAME="NEXVAULT API"
API_V1_STR="/api/v1"

# Relational Database URL
DATABASE_URL="postgresql://neondb_owner:npg_fkoh7jVDvuY8@ep-icy-hat-aolbh46n.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# JWT Auth Secret (Required - use a secure 64-char hex string in production)
SECRET_KEY="supersecretkey_change_in_production"

# Access token lifespan in minutes (10080 minutes = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS Allowed Origins (Comma-separated values or JSON array)
BACKEND_CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# Cookie Security settings (False for local HTTP, True for HTTPS production)
COOKIE_SECURE=False
COOKIE_SAMESITE="lax"
